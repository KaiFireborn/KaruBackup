{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KaruBackupConfig",
  "type": "object",
  "required": ["jobs"],
  "properties": {
    "jobs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "source",
          "precommand",
          "description",
          "style",
          "postcommand",
          "trigger",
          "remote",
          "category"
        ],
        "properties": {
          "description": {
            "type": "string",
            "description": "Job's description, will be notified"
          },
          "category": {
            "type": "string",
            "description": "The backup will be saved in remote_mountpoint/remote_path_from_mountpoint/category/job_name"
          },
          "source": {
            "type": "object",
            "required": [
              "mountpoint",
              "path_from_mountpoint",
              "explicit_exclude",
              "check_if_mounted"
            ],
            "properties": {
              "mountpoint": {
                "type": "string",
                "description": "Absolute source path to the mountpoint, use `/` for root. Must not contain tilde (~); must start and end with `/`"
              },
              "path_from_mountpoint": {
                "type": "string",
                "description": "Path to the folder the contents of which are supposed to be backed up starting from the mountpoint specified separately. Must end but not start with `/`"
              },
              "check_if_mounted": {
                "type": "boolean",
                "description": "if true and the mount dir isn't a mountpoint, aborts job. Set to false if the path is on the / drive or an RSYNC remote!"
              },
              "explicit_exclude": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "precommand": {
            "type": "string"
          },
          "style": {
            "type": "object",
            "required": ["mode"],
            "properties": {
              "mode": {
                "type": "string",
                "enum": [
                  "custom",
                  "rsync_basic",
                  "rclone_basic",
                  "restic_basic",
                  "encrypted"
                ],
                "description": "Choose `rclone_basic` if backing up to or from rclone remote; Choose `rsync_basic` (simple) or `restic_basic` (incremental) for backups on the same filesystem or to attached disks; Choose `restic_basic`."
              },
              "main_command": {
                "type": "string",
                "description": "Custom command formatting template string."
              }
            },
            "if": {
              "properties": {
                "mode": {
                  "const": "custom"
                }
              }
            },
            "then": {
              "required": ["main_command"]
            }
          },

        "if": {
              "properties": {
                "mode": {
                  "const": "encrypted"
                }
              }
            },
            "then": {
              "required": ["passphrase"]
            }
          },
          "postcommand": {
            "type": "string"
          },
          "trigger": {
            "type": "object",
            "required": ["unit", "every_n_units"],
            "properties": {
              "unit": {
                "type": "string",
                "enum": ["minute", "hour", "day", "week"],
                "description": "Allowed schedule units checked by Python switch-case."
              },
              "every_n_units": {
                "type": "integer",
                "minimum": -1,
                "description": "Interval frequency. -1 means manual_only, 0 means on_update."
              }
            }
          },
          "remote": {
            "required": [
              "mountpoint",
              "path_from_mountpoint",
              "check_if_mounted"
            ],
            "mountpoint": {
              "type": "string",
              "description": "Absolute path to mountpoint, must start and end with /, no ~ allowed."
            },
            "check_if_mounted": {
              "type": "boolean",
              "description": "if true and the mount dir isn't a mountpoint, aborts job. Set to false if the path is on the / drive or an RSYNC remote!"
            },
            "path_from_mountpoint": {
              "type": "string",
              "description": "Relative path of folder to back up to starting at specified mountpoint. Must end but not start with /"
            }
          }
        }
      }
    }
  }
}
